# Copy this file to config.env and edit it.

# Base Technitium URL, no trailing slash.
TECHNITIUM_URL="http://127.0.0.1:5380"

# Recommended for automation: create a non-expiring API token in Technitium
# and paste it here.
TECHNITIUM_TOKEN="replace-with-api-token"

# Shared domain list file.
DOMAIN_LIST="$(cd "$(dirname "$0")" && pwd)/domains.txt"

# Optional: write a run log here.
LOG_FILE="$(cd "$(dirname "$0")" && pwd)/technitium-cron.log"

# Optional cluster node name. Leave empty to target the current node.
TECHNITIUM_NODE=""

# Optional behavior toggles.
REMOVE_FROM_ALLOWED_ON_BLOCK=0
ADD_TO_ALLOWED_ON_UNBLOCK=0

# Curl timeout in seconds.
CURL_TIMEOUT=30
